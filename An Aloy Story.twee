// Vault laden
setup.gossipTextVault = null;

setup.loadGossipVault = function () {
    if (!setup.gossipTextVault) {
        setup.gossipTextVault = JSON.parse(
            Story.get("GossipTexte").text
        );
    }
};

// ========================
// GOSSIP TRACKING
// ========================

setup.markGossipSeen = function (storyId, success = false) {
    if (!State.variables.world.seenGossip) {
        State.variables.world.seenGossip = {};
    }
    const existing = State.variables.world.seenGossip[storyId];
    if (existing) {
        existing.success = success;
    } else {
        State.variables.world.seenGossip[storyId] = {
            id: storyId,
            success: success
        };
    }
};

setup.hasSeenGossip = function (storyId) {
    const seen = State.variables.world.seenGossip || {};
    return Object.prototype.hasOwnProperty.call(seen, storyId);
};

setup.wasGossipSuccessful = function (storyId) {
    const seen = State.variables.world.seenGossip || {};
    const entry = seen[storyId];
    return entry ? entry.success === true : false;
};

// ========================
// HILFSFUNKTION
// ========================

setup.getAllGossipStories = function () {
    setup.loadGossipVault();
    const vault = setup.gossipTextVault;
    if (!vault || !vault.stories) {
        return [];
    }
    return [
        ...(vault.stories.lagerklatsch || []),
        ...(vault.stories.landesinfos || []),
        ...(vault.stories.knaller || [])
    ];
};

// ========================
// NEUE GESCHICHTEN
// ========================

setup.getGossipStory = function () {
    const gossipLevel = State.variables.player.knowledge.gossip || 0;
    const allStories = setup.getAllGossipStories();
    const seen = State.variables.world.seenGossip || {};

    const available = allStories.filter(function (story) {
        if (Object.prototype.hasOwnProperty.call(seen, story.id)) {
            return false;
        }
        if (gossipLevel < story.minLevel) {
            return false;
        }
        if (gossipLevel > story.maxLevel) {
            return false;
        }
        return true;
    });

    if (available.length === 0) {
        return null;
    }

    return available[Math.floor(Math.random() * available.length)];
};

// ========================
// FEHLGESCHLAGENE GESCHICHTEN
// ========================

setup.getFailedGossipStory = function () {
    const gossipLevel = State.variables.player.knowledge.gossip || 0;
    const allStories = setup.getAllGossipStories();
    const seen = State.variables.world.seenGossip || {};

    const failed = allStories.filter(function (story) {
        const entry = seen[story.id];

        if (!entry) {
            return false;
        }
        if (entry.success === true) {
            return false;
        }
        if (gossipLevel < story.minLevel) {
            return false;
        }
        if (gossipLevel > story.maxLevel) {
            return false;
        }
        return true;
    });

    if (failed.length === 0) {
        return null;
    }

    return failed[Math.floor(Math.random() * failed.length)];
};

// ========================
// PROBE BERECHNEN
// ========================

setup.rollGossipProbe = function (skill, difficulty) {
    if (difficulty === 0) return true;
    
    const dice = Math.floor(Math.random() * 10) + 1;
    
    // Einsteigerbonus: skill 1-2 hat immer mindestens 80% Chance
    if (skill >= 1 && skill < 3) {
        return dice <= 8; // 8 von 10 = 80%
    }
    
    return dice + skill >= difficulty + 5;
};

setup.getProbeThoughtText = function (skill, difficulty) {
    const vorsprung = skill - difficulty;
    
    if (skill < difficulty - 2) return null; // kein Link
    
    if (vorsprung >= 4) return "Du kennst diese Sorte Gespräch. Der Typ will reden — er braucht nur den richtigen Moment. Den kannst du ihm geben.";
    if (vorsprung >= 2) return "Da ist noch was. Du bist dir nicht sicher ob er redet, aber die Chance ist da. Die Frage ist wie du fragst.";
    return "Vielleicht steckt mehr dahinter. Vielleicht auch nicht. Nachhaken könnte klappen — oder den Abend beenden.";
};


// ========================
// PROBE GESCHAFFT GEDANKENBOX
// ========================

setup.getSuccessThought = function (skill, difficulty) {
    const texts = {
      1: "Du weißt nicht genau was du richtig gemacht hast. Aber es hat funktioniert.",
      3: "Die Stimmen um euch herum werden lauter. Oder ihr werdet leiser. Schwer zu sagen. Er redet jedenfalls.",
      5: "Da ist es. Der Moment wo jemand aufhört abzuwägen ob er redet — und einfach redet.",
      7: "Der Mann lehnt sich vor. Kaum merklich — aber es ist da. Du hast den richtigen Nerv getroffen.",
      9: "Du hast es nicht mal wirklich versucht. Und trotzdem redet er.",
      
}
    
    const thresholds = Object.keys(texts)
        .map(Number)
        .sort((a, b) => a - b);

    let result = texts[thresholds[0]];

    for (const threshold of thresholds) {
        if (skill >= threshold) {
            result = texts[threshold];
        }
    }

  	return '<div class="thought-box">' + result + '</div>';
};

:: StoryStylesheet [stylesheet]
/* STANDARD = NICHT zentriert */
.passage {
    text-align: left;
}

#ui-bar-history {
    display: none;
}

.chapter-screen {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

/* KAPITEL SCREEN = zentriert NUR hier */
/* Gemeinsamer Screen für Intro + Kapitel */
.chapter-screen {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
}

/* Intro bleibt wie gehabt */
.fade-trigger {
    font-size: 48px;
    opacity: 0;

    animation:
        fadeIn 1.5s ease forwards,
        fadeOut 1.5s ease forwards;

    animation-delay:
        0s,
        3s;
}

/* Kapitel-Titel */
.chapter-title {
    font-size: 48px;
    font-weight: bold;
    letter-spacing: 0.08em;
    opacity: 0;

    animation:
        fadeIn 1.5s ease forwards,
        fadeOut 1.5s ease forwards;

    animation-delay:
        0s,
        3s;
}

/* Zeit-Text kommt nach dem Kapitel-Titel */
.chapter-time {
    font-size: 24px;
    margin-top: 0.75em;
    opacity: 0;

    animation:
        fadeIn 1.5s ease forwards,
        fadeOut 1.5s ease forwards;

    animation-delay:
        1.5s,
        3s;
}

/* Link */
.center-link {
    margin-top: 2em;
    min-height: 2em;
    text-align: center;
}

/* Fade In */
@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

/* Fade Out */
@keyframes fadeOut {
    from { opacity: 1; }
    to { opacity: 0; }
}




.journal-link {
    text-align: right;
    margin: 0;
    padding: 0;
}
/* --- HUD HEADER --- */

#hud-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 4px 4px 4px;
    margin-bottom: 0;
    flex-wrap: wrap;
    gap: 0.4em;
}

.hud-left {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6em;
    align-items: center;
}

.hud-right {
    margin-left: auto;
    white-space: nowrap;
}

/* Einzelne HUD-Chips */
.hud-item {
    font-size: 0.82em;
    font-variant: small-caps;
    letter-spacing: 0.04em;
    color: #a39e93;
    background: #1a1917;
    border: 1px solid #2d2b27;
    border-radius: 2px;
    padding: 2px 8px;
}

/* Notizbuch-Knopf: erbt den Link-Style, aber kompakter */
.hud-right a.link-internal {
    display: inline-block !important;
    padding: 4px 14px !important;
    margin-bottom: 0 !important;
    font-size: 0.88em !important;
    font-variant: small-caps;
    letter-spacing: 0.04em;
    border-left-width: 2px !important;
    transform: none !important;
}

.hud-right a.link-internal:hover {
    transform: none !important;
    border-left-color: #c5b394 !important;
}

.hud-divider {
    margin-top: 6px;
    border-color: #2d2b27;
}

#passage-header {
    margin: 0;
    padding: 0;
}

.npc-entry {
    margin-bottom: 1em;
}

.npc-entry div {
    margin-top: 0.3em;
}

.passage.journalansicht br {
    display: none;
}

.player-stats {
    width: 100%;
    border-collapse: collapse;
  	table-layout: fixed;
}

.player-stats th,
.player-stats td {
    border: 1px solid white;
    padding: 4px 8px;
  	text-align: center;
}

.player-stats th {
    font-weight: bold;
}

/* --- DIALOGE & STIMMEN --- */

/* Laut, aggressiv, gebrüllt */
.voice-aggressive {
    color: #e05252;         /* Klares Blutrot */
    font-weight: bold;
    letter-spacing: 0.05em;
}

/* Geflüstert, heimlich, bedrohlich ruhig */
.voice-whisper {
    color: #7ab3a0;         /* Gedämpftes Seegrün – kalt, still, unheimlich */
    font-style: italic;
    font-size: 0.95em;
}

/* Feierlich, formell, diplomatisch */
.voice-formal {
    color: #c9a84c;         /* Sattes Ocker/Gold – würdevoll, aber nicht Messing */
    font-variant: small-caps;
    letter-spacing: 0.03em;
}


/* --- ATMOSPHÄRE & UMGEBUNG --- */

/* Umgebungsbeschreibungen, Wetter, Szenerie */
.scenery-text {
    font-style: italic;
    color: #8a9a7a;         /* Gedämpftes Moosgrün – Natur, Außenwelt, Distanz */
    margin: 1em 0;
    padding-left: 10px;
    border-left: 2px solid #3a4a32;
}

/* Innerer Monolog, Gedanken, Reflexion */
.thought-box {
    background-color: #16161a;
    border: 1px dashed #3a3560;
    padding: 12px;
    margin: 1.2em 0;
    font-size: 0.95em;
    color: #b0a8d8;         /* Gedämpftes Lavendel – introspektiv, träumerisch */
}


/* --- SYSTEM-MELDUNGEN & WERTE --- */

.system-alert {
    padding: 10px;
    margin: 0.8em 0;
    border-radius: 4px;
    font-size: 0.9em;
    font-weight: bold;
}

/* Positiv */
.status-positive {
    background-color: #1b2b1c;
    border: 1px solid #2e5230;
    color: #73c976;         /* Grün – bleibt, ist eindeutig */
}

/* Negativ */
.status-negative {
    background-color: #2b1b1b;
    border: 1px solid #522e2e;
    color: #e57373;         /* Rot – bleibt, ist eindeutig */
}

/* Neutral/Info */
.status-info {
    background-color: #22252a;
    border: 1px solid #3b424c;
    color: #a3b8cc;         /* Stahlblau – bleibt */
}

/* Beziehungs-gesteuerter Text */
.beziehung {
    display: block;
    border-left: 2px solid #7a5c8a;   /* Gedämpftes Violett – eigene Identität */
    padding-left: 0.8em;
    color: #b08acc;                    /* Helles Lavendel/Rosa-Lila */
    font-style: italic;
    margin: 0.5em 0;
}










/* Styling für das Sandbox-Auswahlmenü - Militärischer Akademie-Look */
.sandbox-menu {
    list-style-type: none;
    padding-left: 0;
    margin: 2em 0;
}

.sandbox-menu li {
    background-color: #1a1917; /* Dunkles Ruß-Schwarz/Braun statt dem kühlen Gedanken-Blau */
    border: 1px solid #2d2b27;  /* Mattes, dreckiges Dunkelgrau */
    border-left: 4px solid #5a564c; /* Altes, stumpfes Eisen */
    padding: 15px 20px;
    margin-bottom: 1em;
    border-radius: 2px; /* Eckiger und härter als die weichen Gedanken-Boxen */
    transition: all 0.2s ease-in-out;
}

/* Hover-Effekt: Der physische Ort wird "beleuchtet" */
.sandbox-menu li:hover {
    background-color: #24221f; /* Helleres Lagerfeuer-Asche-Grau */
    border-color: #4a453d;
    border-left-color: #c5b394; /* Stumpfes Messing/Kettenhemd-Silber leuchtet auf */
    transform: translateX(4px);
}

/* Die Links (Die Orte im Lager) */
.sandbox-menu li a {
    font-weight: bold;
    font-size: 1.15em;
    color: #dfdcd6 !important; /* Mattes Pergament-Weiß statt dem kühlen Magie-/Gedanken-Weiß */
    text-decoration: none;
    display: inline-block;
    margin-bottom: 0.3em;
}

/* Wenn man den Link direkt hovert */
.sandbox-menu li a:hover {
    color: #fff !important;
}

/* Die atmosphärische Beschreibung der Station */
.sandbox-menu .subtext {
    display: block;
    font-size: 0.95em;
    color: #a39e93; /* Dreckiges Staub-Grau, das sich klar vom Flüstern abhebt */
    line-height: 1.4;
}

/* --- LINKS & ENTSCHEIDUNGEN --- */

/* --- PASSAGE-LINKS als Panel-Buttons --- */

#passages a.link-internal {
    display: block;
    background-color: #1a1917;
    border: 1px solid #2d2b27;
    border-left: 4px solid #5a564c;
    padding: 12px 18px;
    margin-bottom: 0.75em;
    border-radius: 2px;
    color: #dfdcd6;
    font-weight: bold;
    font-size: 1.05em;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
}

#passages a.link-internal:hover {
    background-color: #24221f;
    border-color: #4a453d;
    border-left-color: #c5b394;
    color: #fff;
    transform: translateX(4px);
    cursor: pointer;
}

#passages a.link-internal:visited {
    color: #8a7f6e;
    border-left-color: #3d3a34;
}