    known: false,
    faction: "84. Banner",
    affection: 0,
    trust: 0,
    isRealPlayer: true,
    memory: { flags: {}, events: [] },
    journalEntry: "Armbruster und Fahnenträger des 84. Banners, Gebirgsmarine-Ausbildung. Kein Bart, lange Haare, große Klappe. Zitiert pausenlos seinen Opa. Trinkt mehr als gut ist und wird dabei nie laut. "
},

diplomatHannes: {
