:: Kap1_Der_naechste_Tag_Texte {"position":"1525,800","size":"100,100"}
{
  "morgen": [
    {
      "text": "Das erste Licht kriecht durch die Ritzen der Baracke wie ein Bote, der weiß, dass er nicht willkommen ist. Es ist noch kein richtiger Tag — nur das blasse Versprechen davon. Draußen beginnt irgendwo ein Horn zu rufen, und das Lager erwacht, langsam und ohne Gnade.",
      "context": { "weather": "klar" }
    },
    {
      "text": "Regen gegen das Holz. Gleichmäßig, trocken, gnadenlos. Draußen werden die Stiefel schwer werden vom ersten Schritt an, und der Dreck des Appellplatzes wird heute kein Staub, sondern Matsch sein. Du weißt das, noch bevor du die Augen aufmachst.",
      "context": { "weather": "regen" }
    },
    {
      "text": "Nebel liegt über dem Lager wie ein zweiter Vorhang, dichter als der erste. Die Baracke riecht nach feuchtem Holz und dem Atem von dreißig Männern. Draußen sind die Konturen der Palisaden verschwommen, und die Wachen klingen weiter weg als sie sind.",
      "context": { "weather": "neblig" }
    },
    {
      "text": "Die Kälte dieser Nacht hat sich zwischen die Bohlenwände gefressen und hält sich noch fest. Du atmest und siehst deinen Atem. Ein Geräusch wie Holzknacken — das Gebäude selbst, das sich gegen den Frost behauptet. Draußen ist der Exerzierplatz sicher weiß und hart.",
      "context": { "weather": "frostig" }
    },
    {
      "text": "Wind presst gegen die Baracke von der westlichen Seite. Das Holz gibt nach und federt wieder, ein leises, stetiges Atmen der Wände. Das Horn klingt anders als sonst — zerfetzt, in Fetzen, die der Wind davonträgt bevor sie ankommen.",
      "context": { "weather": "windig" }
    },
    {
      "text": "Donnern. Nicht das Donnern der Kanonen am Schießstand — tiefer, weiter, ohne Richtung. Ein Gewitter irgendwo hinter den Bergen, das langsam näherwandert. Das Horn ruft trotzdem. Das Horn ruft immer.",
      "context": { "weather": "gewitter" }
    },
    {
      "text": "Der Morgen kommt ohne Ankündigung, so wie alle Morgen hier. Das Horn. Der Reflex, aufzustehen. Der Körper, der es tut, noch bevor der Kopf gefragt hat. Irgendwann wird das zur zweiten Natur sein. Noch ist es nur Gehorsam.",
      "context": {}
    },
    {
      "text": "Ein graues Licht kriecht unter die Tür. Es ist nicht schön, aber es ist eindeutig: Der Tag hat begonnen. Du hast keine Wahl, als ihm zu folgen.",
      "context": {}
    },
    {
      "text": "Der Morgen riecht nach Küchenfeuer — irgendwo wird die Suppe bereits angesetzt. Es ist kein angenehmer Geruch. Aber er bedeutet, dass jemand früher aufgestanden ist als du, und das bedeutet Essen, und das ist genug.",
      "context": {}
    }
  ],

  "koerper": [
    {
      "text": "Deine Handflächen tun noch weh von gestern. Die Pike lässt keine sanften Spuren. Hornhaut bildet sich langsam — aber noch nicht schnell genug.",
      "context": { "activity": "pike" }
    },
    {
      "text": "Der Schwefelgeruch sitzt noch immer in der Kleidung. Du wirst ihn bis zum nächsten Waschen nicht loswerden. Ein paar der anderen rümpfen die Nase, als du an ihnen vorbeigehst.",
      "context": { "activity": "cannon" }
    },
    {
      "text": "Du streckst die Finger und prüfst instinktiv die Beugung. Der Wundarzt gestern hatte kalte Hände und einen warmen Blick — du hast beides bemerkt.",
      "context": { "activity": "medicine" }
    },
    {
      "text": "Die Schulter, an der die Sehne gestern gezogen hat, schmerzt mit einer dumpfen, vertrauten Beharrlichkeit. Armbrust. Du hast keine Ahnung, wie viele Schuss es braucht, bis der Körper aufhört zu klagen.",
      "context": { "activity": "crossbow" }
    },
    {
      "text": "Du weißt jetzt, welche Wachablösung wann kommt, und welche Lücke zwischen Planwagen und Palisade breit genug ist, um ungesehen zu passieren. Das Wissen sitzt wie ein kleines, stilles Gewicht hinter dem Sternum.",
      "context": { "activity": "thievery" }
    },
    {
      "text": "Die Gesprächsfetzen des gestrigen Abends kehren zurück, klarer jetzt als im Moment ihres Entstehens. Namen. Andeutungen. Halbe Wahrheiten. Du tust nichts damit — noch nicht.",
      "context": { "activity": "gossip" }
    },
    {
      "text": "Dein Körper weiß bereits, was ihn erwartet. Er hat aufgehört zu fragen, ob er will.",
      "context": {}
    },
    {
      "text": "Die Muskeln melden sich. Nicht dramatisch. Nur ein leises, stetiges Brennen, das daran erinnert, dass gestern tatsächlich passiert ist.",
      "context": {}
    },
    {
      "text": "Du stehst auf, und der Körper tut es mit dir. Das ist mehr, als du nach dem ersten Tag für möglich gehalten hättest.",
      "context": {}
    }
  ],

  "gedanke": [
    {
      "text": "Tag <<= $world.day>> in der Akademie. Ich zähle. Ich weiß, dass ich irgendwann aufhören muss zu zählen — aber noch bin ich nicht so weit.",
      "context": { "maxDay": 10 }
    },
    {
      "text": "Ich hätte nicht gedacht, dass Erschöpfung eine eigene Struktur hat. Aber sie hat eine. Sie legt sich über alles andere, und darunter liegen dann die echten Gedanken. Irgendwann komme ich zu ihnen.",
      "context": { "minDay": 3, "maxDay": 20 }
