};

setup.addItem = function (itemName) {
    const player = State.variables.player;
    if (!player || !Array.isArray(player.inventory)) return "";

    player.inventory.push(itemName);
    return '<div class="system-alert status-positive">Gegenstand erhalten: ' + itemName + '</div>';
};

setup.hasItem = function (itemName) {
    const player = State.variables.player;
    if (!player || !Array.isArray(player.inventory)) return false;

    return player.inventory.includes(itemName);
};

setup.isFactionKnown = function(factionString) {
    return Object.values(State.variables.npc).some(npc => 
        npc.faction === factionString && npc.known === true
    );
};

setup.getRandomKnownNpcByFaction = function(factionString) {
    const known = Object.values(State.variables.npc).filter(npc => 
        npc.known === true && npc.faction === factionString
    );
    if (known.length === 0) return null;
    return known[Math.floor(Math.random() * known.length)].name;
};

setup.getKonditionLabel = function (k) {
    if (k >= 90) return "💪 Bestform";
    if (k >= 70) return "🟢 Fit";
    if (k >= 50) return "🟡 Angeschlagen";
    if (k >= 30) return "🟠 Erschöpft";
    if (k >= 10) return "🔴 Am Limit";
    return "💀 Zusammenbruch";
};

//------------------------WORLD SECTION


setup.resetDailyVariables = function() {
	const world = State.variables.world;
    const player = State.variables.player;
    const weatherConditions = [
    "sonnig", 
    "klar", 
    "heiter",
    "wolkig", 
    "bewoelkt", 
    "stark_bewoelkt",
    "regen", 
    "schauer", 
    "nieselregen",  
    "frostig",
    "windig", 
    "gewitter", 
    "neblig", 
    "schwuel"
  ];
  	
  	const rnd = Math.floor(Math.random() * weatherConditions.length);
  	world.weather = weatherConditions[rnd];
    world.wasPracticing = false;
  	world.day+=1
  	// --- Kondition: zehrt jeden Tag, Sterben nur durch Vernachlässigung ---
    if (player.hasSlept) {
    // Erholung durch Schlaf
    	world.kondition = Math.min(100, world.kondition + 10);
	} else {
    // Schlafmangel
    	world.kondition = Math.max(0, world.kondition - 10);
	}

    // --- Plotdruck steigt passiv, solange Sidequest offen ist ---
    const k = State.variables.npc.karla;
    const j = State.variables.npc.jarek;
    if (k && !k.memory.flags.sidequest00Complete) world.karla_druck += 1;
    if (j && !j.memory.flags.sidequest01Complete) world.jarek_druck += 1;

    world.interruptDoneToday = false;
  	
};

setup.setKondition = function (modifier) {
    const world = State.variables.world;
    if (!world) {
        console.warn("World nicht gefunden");
        return "";
    }
    world.kondition = world.kondition + modifier;
    if (modifier < 0) {
        return '<div class="system-alert status-negative">Kondition verringert</div>';
    } else if (modifier > 0) {
        return '<div class="system-alert status-positive">Kondition erhöht</div>';
    }
    return "";
};

setup.routeTags = {
    nach_hub:    "Nachmittag Hub",
    nach_appell: "Abendappell",
    nach_stube:  "Auf Stube",
  	nach_morgen: "Kap1_Der nächste Tag" 
};



/*==============================================================
  INTERRUPTS
==============================================================*/
setup.checkInterrupt = function () {
    const w = State.variables.world;
    if (w.interruptDoneToday) return null;
    const hist = w.interruptHistory;

    // Eignung: nicht auf Cooldown, nicht verbrauchter Einmaliger
    const eligible = name => {
        const passage = Story.get(name);
        if (!passage) return false;
        if (passage.tags.includes("einmalig") && hist[name]) return false;
        const cd = setup.interruptCooldown[name] || 3;
        if (hist[name] && (w.day - hist[name]) < cd) return false;
        return true;
    };

    // --- NUR Passagen mit dem Tag "interrupt" kommen in den Pool ---
    // Routing-Tags (nach_morgen, einmalig, nach_stube ...) auf Folge-Passagen
    // stören den Pool damit nicht mehr.
    const pool = Story.lookupWith(p => p.tags.includes("interrupt"))
                      .map(p => p.title);

    // --- 1. PFLICHT: hat eine Bedingung UND sie ist erfüllt -> muss feuern ---
    const pflicht = pool
        .filter(name => setup.interruptCond[name])
        .filter(name => setup.interruptCond[name](w))
        .filter(eligible)
        .sort((a, b) => (setup.interruptPrio[b] || 0) - (setup.interruptPrio[a] || 0));

    if (pflicht.length > 0) {
        const winner = pflicht[0];
        hist[winner] = w.day;
        w.interruptDoneToday = true;
        return winner;
    }

    // --- 2. ZUFALL: keine Bedingung -> normaler Pool ---
    const zufall = pool
        .filter(name => !setup.interruptCond[name])
        .filter(eligible);

    if (zufall.length === 0) return null;
    if (Math.random() > (w.interruptChance || 0.35)) return null;

    const winner = zufall[Math.floor(Math.random() * zufall.length)];
    hist[winner] = w.day;
    w.interruptDoneToday = true;
    return winner;
};

// Liest aus den Tags der aktuellen Passage das Rücksprungziel
setup.routeFromTags = function (tagList) {
    const player = State.variables.player;
    for (const t of tagList) {
        player.hasSlept = (t !== "nach_morgen");
        if (setup.routeTags[t]) return setup.routeTags[t];
    }
    player.hasSlept = true;
    return "Nachmittag Hub";
};

