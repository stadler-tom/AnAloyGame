:: Wuerfel_Zuschauen {"position":"2450,2350","size":"100,100"}
<<if $world.needsDiceGame>> \

Du willst dich gerade abwenden, als eine Stimme hinter dir schneidet.

„Wirklich?“

Karla steht schon hinter dir, viel zu nah.

Ein schiefes Grinsen zieht über ihr Gesicht, während sie deinen Blick festhält.

„Du gehst nirgendwo hin.“

Bevor du reagieren kannst, packt sie dich am Kragen und zieht dich zurück an den Tisch.


[[Der Würfel klackt auf Holz->Wuerfel_Start]] 

<<else>>

Du lehnst dich zurück.

Die Würfel rollen gleichmäßig über das Holz, begleitet von gedämpftem Lachen und dem leisen Klirren leerer Krüge.

Für einen Moment bist du nur Zuschauer.

Die Wärme des Raumes, das monotone Klacken der Würfel und das leise Murmeln der Rekruten ziehen langsam an dir vorbei.

Deine Augen werden schwer.
Nicht plötzlich – eher so, als würde die Müdigkeit sich einfach neben dich setzen und nicht mehr weggehen.

<<timed 9s>>
    Die Geräusche verschwimmen.
    Stimmen werden zu etwas Fernem, Unwichtigem.
<</timed>>

<<timed 13s>>
    Irgendwann merkst du kaum noch, dass du noch wach bist.
<</timed>>

<<timed 16s>>
    Dein Kopf sinkt leicht nach vorne.

    Niemand sagt etwas dagegen.
    In einer Kaserne schläft jeder irgendwann irgendwo ein.
    
    [[schlafen->Kap1_Der nächste Tag]]
<</timed>>
<</if>>


:: journalAnsicht {"position":"700,0","size":"100,100"}
<div id="passage-journalansicht" class="passage journalansicht">
  <h2>📋 $player.name's Notizbuch</h2>
  Hier sind deine bisherigen Erkenntnisse über die Personen in der Akademie von Ohm festgehalten:
  <h3>Inventar und Werte</h3>
  <<print setup.renderPlayerTable()>>
  <h3>Personen in der Militärakademie</h3>
  <<print setup.renderJournal()>>
  ---
  <h3>Gerüchte</h3>
  <<print setup.renderRumors()>>

</div>
<<back "↩️ Zurück zum Dienst">>


:: StoryScript [script]
Config.history.maxStates = 2;
Config.debug = false;



/*==============================================================
CONTITIONAL INTERRUPTS
==============================================================*/

setup.interruptCond     = {};   // optional: "Name" -> w => boolean
setup.interruptCooldown = {};   // optional: "Name" -> Tage (sonst Default 3)
setup.interruptPrio     = {};   // NEU: höher = wird zuerst gefeuert

/*ab hier Prios und conditions eintragen*/
setup.interruptCond["Story002_Taverne_mit_Lars_Und_Hadde"] = w => w.day >= 8;
setup.interruptPrio["Story002_Taverne_mit_Lars_Und_Hadde"] = 60;
setup.interruptCond["Story003_ErsterMorgen"] = w => w.day == 2;





setup.money = {
  copperPerSilver: 7,
  silverPerGold: 10,
}




postdisplay["world-tracker"] = function () {
    const forbidden = [
        "journalAnsicht"
    ];

    const title = State.current.title;

    if (forbidden.includes(title)) return;

    State.variables.world ||= {};
    State.variables.world.lastPassage = title;
  
    Save.slots.save(0);
	
};

predisplay["tagesstart"] = function () {
    if (tags().includes("tagesstart")) {
        setup.resetDailyVariables();
    }
};

setup.noJournalPages = [
    "Intro",
    "Das Erwachen",
    "journalAnsicht",
  	"Nachmittag Pike",
  	"Nachmittag Cannon",
  	"Nachmittag Medicine",
  	"Nachmittag Crossbow",
  	"Nachmittag Thievery"
];

setup.isJournalBlocked = function () {
    const p = passage();

    // feste Sperrliste
    if (setup.noJournalPages.includes(p)) {
        return true;
    }

    // dynamisch: Kapitel 1, Kapitel 2, ...
    if (p.startsWith("Kapitel")) {
        return true;
    }

    return false;
};

setup.renderPlayerTable = function () {
    const p = State.variables.player;
  
  	const money = setup.getMoney(p.money.copper);
  
    const inventoryHTML =
        p.inventory.length === 0
            ? `<tr><td colspan="3" style="font-style: italic; color: #888;">Inventar ist leer</td></tr>`
            : p.inventory.map(item =>
                `<tr><td colspan="3">${item}</td></tr>`
            ).join("");
  	

    return `
    <h3 class="voice-formal">Spielerwerte</h3>
    <table class="player-stats">

        <tr><th colspan="3" class="voice-formal">Persönliches</th></tr>
        <tr><td colspan="1">Name</td>
        <td colspan="2">Rang</td></tr>
        <tr><td colspan="1">${p.name}</td>
        <td colspan="2">${p.rank}</td></tr>     
        
        <tr><th colspan="3" class="voice-formal">Charaktereigenschaften (Stats)</th></tr>
        <tr><td>Gnade</td>
        <td>Ehrgeiz</td>
        <td>Ehrlichkeit</td></tr>
        <tr><td>${p.stats.mercy}</td>
        <td>${p.stats.ambition}</td>
        <td>${p.stats.honesty}</td></tr>
        
        <tr><th colspan="3" class="voice-formal">Kampfwerte &amp; Wissen (Knowledge)</th></tr>
        <tr><td>Pike &amp; Hellebarde</td>
        <td>Artillerie-Wissen</td>
        <td>Armbrust-Präzision</td></tr>
        <tr><td>Level ${p.knowledge.pike}</td>
        <td>Level ${p.knowledge.cannon}</td>
        <td>Level ${p.knowledge.crossbow}</td></tr>
        
        <tr><td>Heilkunde</td>
        <td>Schattenarbeit</td>
        <td>Gerüchteküche</td></tr>
        <tr><td>Level ${p.knowledge.medicine}</td>
        <td>Level ${p.knowledge.thievery}</td>
        <td>Level ${p.knowledge.gossip}</td></tr>
        
        <tr><th colspan="3" class="voice-formal">Reputation</th></tr>
        <tr><td>Land</td>
        <td>Ohm</td>
        <td>Kirche</td></tr>
        <tr><td>${p.reputation.land}</td>
        <td>${p.reputation.ohm}</td>
        <td>${p.reputation.church}</td></tr>

        <tr><th class="voice-formal">Finanzen</th>
        <td colspan="2">${money.gold} Gold &nbsp;|&nbsp; ${money.silver} Silber &nbsp;|&nbsp; ${money.copper} Kupfer</td></tr>


        <tr><th colspan="3" class="voice-formal">Inventar</th></tr>
        ${inventoryHTML}
    </table>
    `;
};



setup.renderJournal = function () {
    let output = "";
    let found = false;

    for (let key in State.variables.npc) {
        let npc = State.variables.npc[key];

        if (npc.known === true) {
            found = true;
            output += `
                <div class="npc-entry">
                    <b>${npc.name}</b>
                    <div>${npc.journalEntry}</div>
                    <div>Zuneigung: ${npc.affection}</div>
                </div>
            `;
        }
    }

    if (!found) {
        output = "Ich kenne niemanden.";
    }

    return output;
};

//----------------Textbuilding Section & Single Point of Truth

setup.loadTrainingsHubVault = function () {
    if (!setup.trainingsHubTextVault) {
        setup.trainingsHubTextVault = JSON.parse(Story.get("TrainingsHubTexte").text);
    }
};

setup.executeStationRewards = function (stationKey, stationType) {
    var vault = setup.trainingsHubTextVault;
    if (!vault) return "Fehler: TrainingsHub-Daten wurden in StoryInit nicht geladen.";

    var stationData = vault.stations && vault.stations[stationKey] ? vault.stations[stationKey] : null;
    if (!stationData) return "Fehler: Station [" + stationKey + "] nicht gefunden.";

    var rewardAlerts = "";

    // --- AUTOMATISCHE BELOHNUNGS-VERARBEITUNG ---
    // Wir triggern die Wertevergabe nur bei "scenery" (dem ersten Aufruf der Passage)
    if (stationType === "scenery" && stationData.rewards) {
        var r = stationData.rewards;
        
        // 1. Stat-Box direkt von deiner Funktion abfangen
        var statFeedback = setup.setPlayerStat(r.stat, r.statValue);
        if (statFeedback) {
            rewardAlerts += "\n" + statFeedback;
        }

        // 2. Wissens-Box abfangen oder im exakt selben Stil generieren
        var knowledgeFeedback = setup.setPlayerKnowledge ? setup.setPlayerKnowledge(r.knowledge, r.knowledgeValue) : "";
        
        if (knowledgeFeedback) {
            rewardAlerts += "\n" + knowledgeFeedback;
        } else {
            // Fallback im exakt identischen Format, falls setPlayerKnowledge keinen String liefert
            var knowledgeNames = {
                pike: "Pikenkampf",
                cannon: "Artillerie",
                medicine: "Feldscherkunst",
                crossbow: "Armbrustschießen",
                thievery: "Diebeskunst"
            };
            var displayKnowledge = knowledgeNames[r.knowledge] || r.knowledge;
            rewardAlerts += '\n<div class="system-alert status-positive">Wissen (' + displayKnowledge + ') erhöht</div>';
        }

        // Aktivität im Player-Objekt speichern
        State.variables.player.chosen_activity = r.knowledge;
      	State.variables.world.wasPracticing = true;
    }

    // --- SZENERIE-POOL (Levelunabhängig) ---
    if (stationType === "scenery") {
        var pool = stationData.scenery;
        if (!pool || pool.length === 0) return "";
        
        // Hängt die reinen HTML-Boxen direkt per Zeilenumbruch an den Text an
        return pool[Math.floor(Math.random() * pool.length)] + rewardAlerts;
    }

    // --- AUTOMATISCHE LEVEL-ERMITTLUNG ---
    var playerObj = State.variables.player;
    var currentSkill = 0;
    
    if (playerObj && playerObj.knowledge && playerObj.knowledge[stationKey] !== undefined) {
        currentSkill = playerObj.knowledge[stationKey];
    }

    // Stufen-Einteilung
    var levelBracket = "novice"; // Unter Level 4
    if (currentSkill >= 4 && currentSkill <= 7) {
        levelBracket = "medium";
    } else if (currentSkill > 7) {
        levelBracket = "expert";
    }

    // --- TEXT-AUSGABE NACH STUFE ---
    var textPool = stationData[stationType] ? stationData[stationType][levelBracket] : null;
    
    if (!textPool || textPool.length === 0) {
        return "Fehler: Text-Pool für [" + stationType + "] im Level [" + levelBracket + "] nicht gefunden.";
    }
    
    return textPool[Math.floor(Math.random() * textPool.length)];
};

// Beibehalten für direkte/alte Hub-Abrufe falls nötig
setup.getRandomText = function(category, subKey, stationType) {
    var vault = setup.trainingsHubTextVault;
    if (!vault) return "Fehler: TrainingsHub-Daten wurden in StoryInit nicht geladen.";

    if (stationType) {
        return setup.executeStationRewards(subKey, stationType);
    }
    
    if (subKey) {
        var subPool = vault[category] ? vault[category][subKey] : null;
        if (!subPool || subPool.length === 0) return "Fehler: Unterkategorie [" + subKey + "] nicht gefunden.";
        return subPool[Math.floor(Math.random() * subPool.length)];
    }
    
    var pool = vault[category];
    if (!pool || pool.length === 0) return "Fehler: Kategorie [" + category + "] nicht gefunden.";
    return pool[Math.floor(Math.random() * pool.length)];
};


setup.abendappellTextVault = null;

setup.loadAbendappellVault = function () {
    if (!setup.abendappellTextVault) {
        setup.abendappellTextVault = JSON.parse(Story.get("AbendappellTexte").text);
    }
};

setup.getAbendappellText = function (category) {
    setup.loadAbendappellVault();

    var vault = setup.abendappellTextVault;
    if (!vault || !vault[category]) {
        return "Fehler: Abendappell-Kategorie [" + category + "] nicht gefunden.";
    }

    var day      = State.variables.world ? State.variables.world.day : 1;
    var activity = State.variables.player ? State.variables.player.chosen_activity : "";

    var pool = vault[category];

    var contextMatches = pool.filter(function (entry) {
        var ctx = entry.context || {};
        if (ctx.minDay !== undefined && day < ctx.minDay) return false;
        if (ctx.maxDay !== undefined && day > ctx.maxDay) return false;
        if (ctx.activity !== undefined) return ctx.activity === activity;
        return false;
    });

    var genericPool = pool.filter(function (entry) {
        var ctx = entry.context || {};
        if (ctx.minDay !== undefined && day < ctx.minDay) return false;
        if (ctx.maxDay !== undefined && day > ctx.maxDay) return false;
        if (ctx.activity !== undefined) return false;
        return true;
    });

    var finalPool = contextMatches.length > 0 ? contextMatches : genericPool;
    if (finalPool.length === 0) finalPool = pool;

    var pick = finalPool[Math.floor(Math.random() * finalPool.length)];
    return pick ? pick.text : "";
};

setup.naechsterTagTextVault = null;

setup.loadNaechsterTagVault = function () {
    if (!setup.naechsterTagTextVault) {
        setup.naechsterTagTextVault = JSON.parse(Story.get("Kap1_Der_naechste_Tag_Texte").text);
    }
};

setup.getNaechsterTagText = function (category) {
    setup.loadNaechsterTagVault();

    var vault = setup.naechsterTagTextVault;
    if (!vault || !vault[category]) {
        return "";
    }

    var day      = State.variables.world ? State.variables.world.day : 1;
    var weather  = State.variables.world ? State.variables.world.weather : "";
    var activity = State.variables.player ? State.variables.player.chosen_activity : "";

    var pool = vault[category];

    // luigi_schatten: nur selten, ca. 25% Chance, und nur wenn Kontext passt
    if (category === "luigi_schatten") {
        var luigiPool = pool.filter(function (entry) {
            var ctx = entry.context || {};
            if (!ctx.luigi_chance) return false;
            if (ctx.minDay !== undefined && day < ctx.minDay) return false;
            if (ctx.maxDay !== undefined && day > ctx.maxDay) return false;
            return true;
        });

        // 25% Chance, einen Luigi-Moment anzuzeigen
        if (luigiPool.length > 0 && Math.random() < 0.25) {
            var pick = luigiPool[Math.floor(Math.random() * luigiPool.length)];
            return pick ? pick.text : "";
        }
        return ""; // meistens: kein Luigi-Moment
    }

    // Für alle anderen Kategorien: Kontext-Match bevorzugen
    var contextMatches = pool.filter(function (entry) {
        var ctx = entry.context || {};
        if (ctx.luigi_chance) return false; // luigi-Einträge nur über eigenen Zweig
        if (ctx.minDay !== undefined && day < ctx.minDay) return false;
        if (ctx.maxDay !== undefined && day > ctx.maxDay) return false;

        // Wetter-Match (nur wenn weather im context angegeben)
        if (ctx.weather !== undefined) return ctx.weather === weather;

        // Aktivitäts-Match (nur wenn activity im context angegeben)
        if (ctx.activity !== undefined) return ctx.activity === activity;

        return false; // kein generischer Treffer über diesen Pfad
    });

    var genericPool = pool.filter(function (entry) {
        var ctx = entry.context || {};
        if (ctx.luigi_chance) return false;
        if (ctx.minDay !== undefined && day < ctx.minDay) return false;
        if (ctx.maxDay !== undefined && day > ctx.maxDay) return false;
        if (ctx.weather !== undefined) return false;
        if (ctx.activity !== undefined) return false;
        return true;
    });

    var finalPool = contextMatches.length > 0 ? contextMatches : genericPool;
    if (finalPool.length === 0) finalPool = pool.filter(function(e){ return !e.context || !e.context.luigi_chance; });

    var pick = finalPool[Math.floor(Math.random() * finalPool.length)];
    return pick ? pick.text : "";
};


//---------------------NPC Section

setup.setNpcAffection = function (npcKey, modifier) {
    const npc = State.variables.npc?.[npcKey];

    if (!npc) {
        console.warn("NPC nicht gefunden:", npcKey);
        return "";
    }

    npc.affection += modifier;

    if (modifier < 0) {
        return '<div class="system-alert status-negative">Zuneigung von ' + npc.name + ' verringert</div>';
    } else if (modifier > 0) {
        return '<div class="system-alert status-positive">Zuneigung von ' + npc.name + ' erhöht</div>';
    }
    
    return "";
};

setup.pushNpcMemory = function(npcKey, event) {
    const npc = State.variables.npc[npcKey];
    if (npc && npc.memory && Array.isArray(npc.memory.events)) {
        npc.memory.events.push(event);
        return '<div class="system-alert status-info">' + npc.name + ' wird sich das merken</div>';
    }
    return ""; 
};

setup.hasNpcMemory = function(npcKey, event) {
    const npc = State.variables.npc[npcKey];
    if (npc && npc.memory && Array.isArray(npc.memory.events)) {
        return npc.memory.events.includes(event);
    }
    return false;
};

setup.enoughNpcAffection = function (npcKey, requiredValue) {
    const npc = State.variables.npc?.[npcKey];
    if (!npc) return false;
    
    return npc.affection >= requiredValue;
};


//---------------------Player Section

setup.getMoney = function (copper) {

  let silver = Math.floor(copper / setup.money.copperPerSilver)
  let gold = Math.floor(silver / setup.money.silverPerGold)

  silver = silver % setup.money.silverPerGold
  copper = copper % setup.money.copperPerSilver

  return {
    gold,
    silver,
    copper
  }
};



setup.renderRumors = function () {
    if (State.variables.player.rumors.length === 0) {
        return "Noch keine Gerüchte notiert.";
    }

    let out = "";
    for (let r of State.variables.player.rumors) {
        out += `<div>- ${r}</div>`;
    }
    return out;
};

setup.addRumor = function (rumorText) {
    const player = State.variables.player;
    if (!player || !Array.isArray(player.rumors)) return "";

    if (!player.rumors.includes(rumorText)) {
        player.rumors.push(rumorText);
        return '<div class="system-alert status-info">Neues Gerücht im Notizbuch vermerkt.</div>';
    }
    return "";
};

setup.setPlayerStat = function (statKey, modifier) {
    const player = State.variables.player;

    if (!player) {
        console.warn("Player nicht gefunden");
        return "";
    }

    if (!player.stats?.hasOwnProperty(statKey)) {
        console.warn("Stat existiert nicht:", statKey);
        return "";
    }

    player.stats[statKey] = player.stats[statKey] + modifier;

    const statNames = {
        mercy: "Gnade",
        ambition: "Ehrgeiz",
        honesty: "Ehrlichkeit"
    };

    const displayName = statNames[statKey] || statKey;

    if (modifier < 0) {
        return '<div class="system-alert status-negative">' + displayName + ' verringert</div>';
    } else if (modifier > 0) {
        return '<div class="system-alert status-positive">' + displayName + ' erhöht</div>';
    }
    
    return ""; 
};

setup.setPlayerKnowledge = function (knowledgeKey, modifier) {
    const player = State.variables.player;

    if (!player) {
        console.warn("Player nicht gefunden");
        return "";
    }

    if (!player.knowledge?.hasOwnProperty(knowledgeKey)) {
        console.warn("Fähigkeit existiert nicht:", knowledgeKey);
        return "";
    }

    player.knowledge[knowledgeKey] = player.knowledge[knowledgeKey] + modifier;

    const knowledgeNames = {
        pike: "Pike & Hellebarde",
        cannon: "Artillerie-Wissen",
        medicine: "Heilkunde",
        thievery: "Schattenarbeit",
        crossbow: "Armbrust-Präzision",
        gossip: "Gerüchteküche"
    };

    const displayName = knowledgeNames[knowledgeKey] || knowledgeKey;

    if (modifier < 0) {
        return '<div class="system-alert status-negative">' + displayName + ' verringert</div>';
    } else if (modifier > 0) {
        return '<div class="system-alert status-positive">' + displayName + ' verbessert</div>';
    }
    
    return ""; 
};

setup.setPlayerReputation = function (repKey, modifier) {
    const player = State.variables.player;

    if (!player) {
        console.warn("Player nicht gefunden");
        return "";
    }

    if (!player.reputation?.hasOwnProperty(repKey)) {
        console.warn("Fraktion existiert nicht:", repKey);
        return "";
