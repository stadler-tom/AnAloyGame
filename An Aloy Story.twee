:: DEV {"position":"1375,4250","size":"100,100"}
<<run setup.ermInit()>>
<<if not $world.flags>><<set $world.flags = {}>><</if>>


<<if not $world._dbgKap2>>
<<silently>>
<<set $world._dbgKap2 to true>>
<<set $world.day to 365>>
<<set $player.rank to "Waffenträger">>
<<set $player.condition to 70>>
<<set $player.suspicion to 0>>
<<set $player.money.copper to 40>>
<<set $npc.karla.known to true, $npc.jarek.known to true, $npc.magister.known to true>>
<<set $npc.hauptmann.known to true, $npc.kurt.known to true, $npc.schinder.known to true>>
<<set $npc.jarek.memory.flags.katastrophe to true>>
<<set $world.flags.jarek_ausgang to "geschwiegen">>
<<set $world.flags.jarek_ausgang_tag to 360>>
<<set $npc.karla.memory.flags.kapitel1_ende_seen to true>>
<<run ["pike","crossbow","cannon","medicine","thievery","gossip","combat"].forEach(function(k){ State.variables.player.knowledge[k] = 2; })>>
<<set $player.stats.scholarship to 8>>
<<run setup.kapitel1Abschliessen()>>
<</silently>>
<</if>>

<h3>DEBUG: Kapitel-2-Einstieg</h3>

<div class="outcome-box">
<div class="outcome-title">Aktueller Zustand</div>
<p>Tag: <b>$world.day</b> · Jarek-Ausgang: <b>$world.flags.jarek_ausgang</b> · Narbe: <b><<= $player.flags && $player.flags.jareknarbe ? "ja" : "nein">></b><br>
Karla: <b><<= $npc.karla.memory.flags.verhaftung_seen ? "VERHAFTET" : "frei">></b> · Umkehrung: <b><<= $npc.karla.memory.flags.umkehrung_done ? "ja" : "nein">></b> · Zuneigung: <b>$npc.karla.affection</b><br>
Magister: Zuneigung <b>$npc.magister.affection</b> · Archivzugang: <b><<= $edu.archivzugang ? "ja" : "nein">></b><br>
Skills: Pike $player.knowledge.pike · Armbrust $player.knowledge.crossbow · Geschütz $player.knowledge.cannon · Heilkunde $player.knowledge.medicine · Schatten $player.knowledge.thievery · Gerüchte $player.knowledge.gossip · Gelehrsamkeit $player.stats.scholarship<br>
Spezialisierung: <b><<= $player.spezialisierung || "— (noch nicht gewählt)">></b> · Kupfer: <b>$player.money.copper</b> · Kondition: <b>$player.condition</b> · Verdacht: <b>$player.suspicion</b><br>
Ermittlung frühestens Tag: <b><<= $world.ermittlung.fruehestens_tag>></b> · Luigi bekannt: <b><<= $npc.luigi.known ? "ja" : "nein">></b></p>
</div>

<h4>Jarek-Ausgang</h4>
<<link "gemeldet">><<set $world.flags.jarek_ausgang to "gemeldet">><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "geschwiegen">><<set $world.flags.jarek_ausgang to "geschwiegen">><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "schweigen">><<set $world.flags.jarek_ausgang to "schweigen">><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "schande">><<set $world.flags.jarek_ausgang to "schande">><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "Narbe an/aus">><<set $player.flags = $player.flags || {}>><<set $player.flags.jareknarbe to !$player.flags.jareknarbe>><<goto "DEBUG_Kap2_Setup">><</link>>

<h4>Karla</h4>
<<link "Voller Durchlauf (frei, Umkehrung, eng)">>
	<<set $npc.karla.memory.flags.verhaftung_seen to false>>
	<<set $npc.karla.memory.flags.umkehrung_done to true>>
	<<set $npc.karla.memory.flags.kennt_geheimnis to true>>
	<<set $npc.karla.trust to true>>
	<<set $npc.karla.affection to 15>>
	<<goto "DEBUG_Kap2_Setup">>
<</link>> |
<<link "Frei, aber distanziert">>
	<<set $npc.karla.memory.flags.verhaftung_seen to false>>
	<<set $npc.karla.memory.flags.umkehrung_done to false>>
	<<set $npc.karla.trust to false>>
	<<set $npc.karla.affection to 3>>
	<<goto "DEBUG_Kap2_Setup">>
<</link>> |
<<link "Verhaftet (sperrt Ermittlung & Romanze)">>
	<<set $npc.karla.memory.flags.verhaftung_seen to true>>
	<<set $npc.karla.memory.flags.umkehrung_done to false>>
	<<goto "DEBUG_Kap2_Setup">>
<</link>>

<h4>Magister Halm</h4>
<<link "Gunst hoch + Archivzugang">><<set $npc.magister.affection to 6>><<set $edu.archivzugang to true>><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "Neutral, kein Zugang">><<set $npc.magister.affection to 0>><<set $edu.archivzugang to false>><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "Verbrannt (−6)">><<set $npc.magister.affection to -6>><<set $edu.archivzugang to false>><<goto "DEBUG_Kap2_Setup">><</link>>

<h4>Skill-Preset (nach Kapitel-Squash)</h4>
<<link "Allrounder">><<run ["pike","crossbow","cannon","medicine"].forEach(function(k){State.variables.player.knowledge[k]=3;}); State.variables.player.knowledge.thievery=2; State.variables.player.knowledge.gossip=3; State.variables.player.stats.scholarship=10>><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "Schattenläufer">><<run ["pike","crossbow","cannon","medicine"].forEach(function(k){State.variables.player.knowledge[k]=1;}); State.variables.player.knowledge.thievery=4; State.variables.player.knowledge.gossip=4; State.variables.player.stats.scholarship=6>><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "Musterrekrut">><<run State.variables.player.knowledge.pike=4; State.variables.player.knowledge.crossbow=3; State.variables.player.knowledge.cannon=3; State.variables.player.knowledge.medicine=2; State.variables.player.knowledge.thievery=0; State.variables.player.knowledge.gossip=1; State.variables.player.stats.scholarship=14>><<goto "DEBUG_Kap2_Setup">><</link>>

<h4>Spezialisierung (inkl. Waffe)</h4>
<<link "Pike">><<set $player.spezialisierung to "pike">><<run setup.addWeaponToInventory("pike"), setup.equipWeapon("pike")>><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "Armbrust">><<set $player.spezialisierung to "crossbow">><<run setup.addWeaponToInventory("crossbow"), setup.equipWeapon("crossbow")>><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "Geschütz">><<set $player.spezialisierung to "cannon">><<run setup.addWeaponToInventory("hand_cannon"), setup.equipWeapon("hand_cannon")>><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "Feldscher">><<set $player.spezialisierung to "medicine">><<run setup.addWeaponToInventory("field_knife"), setup.equipWeapon("field_knife")>><<goto "DEBUG_Kap2_Setup">><</link>>

<h4>Sonstiges</h4>
<<link "Geld: arm (5)">><<set $player.money.copper to 5>><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "normal (40)">><<set $player.money.copper to 40>><<goto "DEBUG_Kap2_Setup">><</link>> |
<<link "wohlhabend (150)">><<set $player.money.copper to 150>><<goto "DEBUG_Kap2_Setup">><</link>> ·
<<link "Verdacht +10">><<set $player.suspicion to Math.min(100, $player.suspicion + 10)>><<goto "DEBUG_Kap2_Setup">><</link>> ·
<<link "Ermittlung sofort scharf">><<set $world.day to 367>><<set $world.ermittlung.fruehestens_tag to 0>><<set $npc.luigi.known to true>><<goto "DEBUG_Kap2_Setup">><</link>>

<hr class="trenner-raute">

<h4>Starten</h4>
[[Regulär: Kapitel-2-Intro (mit Probe & Waffenwahl)|Kap2_Intro]]
[[Direkt in den Tagesloop (Spezialisierung oben wählen!)|Kap2_Tagesstart]]
[[Biwag|Biwag_Drill]] 


:: Das Erwachen [layout] {"position":"675,150","size":"100,100"}
<<set $showLogo to true>>

<div class="scenery-text">Der Sergeant nickt brummend. Die Feder taucht in die Tinte, kratzt deinen Namen ins Pergament — ein trockenes, endgültiges Geräusch.</div>

<div class="dialog">„Gut. $player.rank $player.name — ab heute gehörst du zum Heer Aloys."</div>

<p>Er lehnt sich nicht zurück. Er verschwendet keine Geste.</p>
<div class="dialog">„Hier in Ohm werden wir euch das Söldner-Handwerk von der Pike auf beibringen. Kein Erlass, kein Erbe, kein Name schützt dich vor dem, was kommt." Ein kurzes Schweigen. „Schnapp dir deine Ausrüstung. Dann meldest du dich beim //Schinder// auf dem Hof."</div>
<p>Den letzten Satz sagt er so, als wäre er eine Warnung. Vielleicht ist er das auch.</p>

<p>Du nimmst, was dir gehört. Es ist nicht viel.</p>
<p>Ein paar einfache Schuhe, zwei Hemden, zwei Beinlinge in Rot und Weiß, eine Bundhaube und ein verschlissener Gürtel. Das alles in einer Umhängetasche verpackt.</p>
<p>In den langen Hallen der Akademie hängen Stimmen in der Luft — gedämpft, aber nicht leise genug. Die Ausbilder tuscheln. Berichte aus dem Feld. Alfaltermark, Greifenorden</p>
<p>Namen und Orte, die dir noch nichts bedeuten.</p>
<p>Noch nicht.</p>
<p>Für dich zählen erst einmal die harten Holzböden der Kaserne in Ohm — und der Mann auf dem Hof, den sie den Schinder nennen.</p>

<<set $npc.sergeant.known = true>>

[[Befehl befolgen und direkt zum Kasernenhof gehen->Der Kasernenhof]]
[[Sich heimlich von der Truppe absetzen und die Akademie-Hallen auskundschaften->Hallen erkunden]]
[[Den Sergeant nach neuen Gerüchten ausfragen->Sergent aushorchen]]


:: Das Training: Erster Tag [kapitel-opener layout] {"position":"450,825","size":"100,100"}
<p>Der Morgen kommt nicht sanft.</p>
<p>Er kommt mit dem Krachen einer Tür, die jemand mit dem Stiefel aufgestoßen hat, und einer Stimme, die keine Rücksicht auf den Schlaf nimmt, den du dir noch nicht geholt hast.</p>
<div class="dialog">„Aufstehen! Raus aus den Federn, ihr Maden! Die Sonne wartet nicht auf Rekruten!"</div>
<p>Du bist auf den Beinen, bevor du wach bist. Der Körper hat bereits begriffen, was der Kopf noch nicht verarbeitet hat. Um dich herum das Chaos von dreißig Menschen, die gleichzeitig nach Stiefeln greifen, Gürtel zuschnallen und sich gegenseitig anrempeln, ohne sich zu entschuldigen. Niemand hat Zeit. Niemand weiß genau, wofür — aber die Dringlichkeit hängt im Raum wie Rauch.</p>

<p>Die Kantine ist laut und riecht nach heißem Fett und gekochtem Gemüse.</p>
<p>Aloyer Allerlei — Schupfnudeln mit Wurzelgemüse, dampfend und reichhaltig, in tiefen Holzschüsseln auf die langen Tische gestellt. Es ist gutes Essen. Nahrhaftes Essen. Unter anderen Umständen würdest du dir die Zeit nehmen, es zu genießen.</p>
<p>Stattdessen löffelst du es stehend halb in dich hinein, weil alle anderen es auch stehend tun, weil niemand sitzen will und als Letzter aufstehen muss, weil die Nervosität im Raum von Tisch zu Tisch springt wie ein Feuer, das sich seinen eigenen Weg sucht. Ein Rekrut verschüttet seinen Becher Wasser. Ein anderer lacht zu laut und hört abrupt damit auf. Niemand spricht über das, worüber alle nachdenken.</p>
<p>Was kommt danach.</p>
<p>Dann fliegt die Kantinentür auf.</p>
<p>Der Sergeant füllt den Rahmen wie ein Naturereignis. Seine Stimme trifft die Wände, bevor irgendjemand reagieren kann.</p>
<div class="dialog">„Auf den Platz! Antreten! Wer in fünf Minuten noch hier steht, lernt den Schinder von seiner ungemütlichen Seite kennen!"</div>
<p>Die Schüsseln bleiben halbvoll. Niemand stellt sie ordentlich hin.</p>

<p>Der Exerzierplatz liegt grau und weit im Morgenlicht. Der Wind ist derselbe wie gestern — er hat die Nacht nicht genutzt, um freundlicher zu werden.</p>
<p>Sie stehen bereits da und warten.</p>
<p>Kurt, mit dem Gesicht eines Mannes, der Rekruten schon gesehen hat, als ihre Väter noch in den Windeln lagen. Neben ihm die Ausbilder, eine Reihe von Männern und Frauen, deren Gesichter alle dasselbe ausdrücken: geduldige, professionelle Gleichgültigkeit. Und dann, einen halben Schritt vor allen anderen, der Schinder.</p>
<p>Er braucht keine Einführung. Er ist einfach da, und das genügt.</p>
<p>Kurt tritt vor. Seine Stimme ist nicht laut, aber sie trägt — die Stimme eines Mannes, der gelernt hat, dass man nicht brüllen muss, wenn man etwas zu sagen hat.</p>
<<if $npc.kurt.affection < 0>>
<p>Du duckst dich unter seinem Blick weg. Versteckst dich in der Masse. Dass du ausgerechnet den Fähnrich verärgert hast ist kein gutes Omen für deine Zeit hier.</p><</if>>
<div class="dialog">„Ich bin Fähnrich Kurt Brasner. Ihr werdet mich Fähnrich nennen, oder ihr werdet mich gar nicht nennen. Ich bin nicht euer Vater, nicht euer Freund und nicht euer Pfaffe." Er lässt seinen Blick einmal langsam über die Reihe wandern. „Ich bin derjenige, der entscheidet, ob ihr in zwei Jahren als Söldner aus diesen Toren geht — oder gar nicht."</div>
<p>Stille.</p>
<p>Kurt tritt zurück.</p>
<p>Ein Mann tritt vor.</p>
<p>Er ist anders als die anderen hier — nicht lauter, nicht größer, aber auf eine Weise präsent, die nichts mit Lautstärke zu tun hat. Hauptmann Konrad Rindler trägt seine Uniform wie ein zweites Ich, jeden Knopf geschlossen, jeden Saum gerade, die Hände ruhig hinter dem Rücken verschränkt. Sein Gesicht ist glatt und kontrolliert, die Augen kühl und aufmerksam — die Augen eines Mannes, der gewohnt ist, Dinge zu bewerten, bevor er sie benennt.</p>
<p>Er lässt sich einen Moment Zeit. Nicht um Eindruck zu schinden. Sondern weil er es kann.</p>
<div class="dialog">„Ich bin Hauptmann Konrad Rindler." Seine Stimme ist ruhig und trägt dennoch bis in die letzte Reihe, ohne dass er sie hebt. „Das 86. Banner existiert noch nicht. Was ihr hier seht — diese Ansammlung von Rekruten auf diesem Platz — das ist der Rohstoff, aus dem es entstehen soll."</div>
<p>Sein Blick gleitet langsam über die Gruppe. Nicht feindselig. Eher wie jemand, der eine Rechnung aufmacht und noch nicht weiß, ob sie aufgehen wird.</p>
<div class="dialog">„Ich werde dieses Banner führen. Was das bedeutet, werden Sie — werdet ihr — in den kommenden zwei Jahren verstehen lernen. Bis dahin gilt: Ihr gehört der Akademie. Ihr gehört dem Fähnrich. Ihr gehört dem Ausbildungskorps." Eine kurze Pause. „Und ihr gehört dem Banner, das wir hier gemeinsam aufbauen werden."</div>
<p>Er tritt zurück. Sauber. Ohne Übergang, ohne Nachsatz.</p>
<p>Als wäre alles Wesentliche gesagt.</p>
<p>Dann tritt schließlich der Schinder vor.</p>
<p>Er stellt sich nicht vor. Er schaut euch an — einen nach dem anderen, als würde er bereits abschätzen, was in jedem von euch steckt und was nicht. Als er schließlich spricht, ist seine Stimme rau wie Schleifstein auf Eisen.</p>
<div class="dialog">„Ihr wollt Söldner werden. Schön. Dann fangen wir damit an, was einen Söldner am Leben hält — nicht Mut, nicht Stärke, nicht der Wille zum Kämpfen." Er lässt die Worte einen Moment stehen. „Formation. Wer nicht in der Formation steht, stirbt als Erster. Wer die Formation bricht, reißt seinen Nebenmann mit in den Tod. Wer den Spieß nicht kennt, ist eine Gefahr für jeden, der neben ihm steht."</div>
<p>Er verschränkt den Lederarm hinter dem Rücken.</p>
<div class="dialog">„Heute lernt ihr, wie man einen Haufen aus dreißig einzelnen Idioten zu einem einzigen Körper macht. Das wird nicht schön. Das wird nicht schnell gehen. Und keiner von euch wird heute Abend zufrieden mit sich sein."</div>
<p>Sein Auge wandert über die Gruppe.</p>
<div class="dialog">„Also."</div>
<p>Eine Pause, kurz und absolut.</p>
<div class="dialog">„Herstellt euch in fünf Reihen!"</div>
<p>Der Befehl kracht über den Platz wie ein Donnerschlag — und dann passiert genau das, was passiert, wenn dreißig Menschen gleichzeitig dasselbe wollen und keiner weiß wie.</p>
<p>Chaos.</p>
<p>Die Mutigsten — oder die Dümmsten, der Unterschied ist im ersten Moment schwer zu erkennen — laufen nach vorne und stellen sich hin, irgendwie, ungefähr. Die anderen folgen zögernd, füllen Lücken, weichen einander aus, stoßen zusammen. Jemand fragt flüsternd seinen Nachbarn, was eine Reihe überhaupt bedeutet. Niemand antwortet mit Überzeugung. Was am Ende entsteht, ist ein schlecht ausgerichtetes Rechteck aus dreißig Menschen, die alle geradeaus schauen und dabei so tun, als hätten sie genau das vorgehabt.</p>
<p>Der Schinder schaut es sich an.</p>
<p>Lange.</p>
<p>Der Schinder geht die erste Reihe ab. Seine schweren Stiefel klatschen rhythmisch in den Matsch des Exerzierplatzes.</p>
<p>Er sagt kein Wort. Er schaut sich nicht einmal die Gesichter an, sondern starrt nur auf die schiefen Schulterlinien,</p>
<p>die ungleichen Abstände und die zitternden Knie. Die Stille, die er erzeugt, ist schlimmer als jedes Brüllen.</p>
<p>Er bleibt genau vor dir stehen. Sein einzelnes Auge fixiert dich, kalt und prüfend.</p>
<div class="dialog">„Eine Reihe“, murmelt er, und seine Stimme ist gefährlich leise. „Ich verlangte fünf Reihen. Was ich sehe, ist ein Haufen betrunkener Bauern auf dem Weg zum Viehmarkt.“</div>
<p>Er tritt einen halben Schritt näher. Sein Atem riecht nach bitterem Kautabak. „Du da. Ja, genau du. Du stehst schief. Deine Schulter hängt,</p>
<p>als hättest du schon jetzt keine Knochen mehr im Leib. Und dein Nebenmann klebt dir an der Hüfte, als wolltet ihr tanzen.“</p>
<p>Er hebt den Holzschaft und deutet auf die Lücke hinter dir.</p>
<p>Der Schinder steht vor dir. Sein Auge wartet.</p>

<<if $npc.karla.affection gt 0>>
<p>@@.beziehung;Karlas Stimme trifft dich von der Seite — kaum mehr als ein Zischen, aber scharf genug um anzukommen. „Beweg dich, Frischling.“@@</p>
<<elseif $npc.jarek.affection gt 0>>
<p>@@.beziehung;Jarek rührt sich nicht. Aber sein rechter Fuß verschiebt sich einen halben Schritt — langsam, bewusst, so dass du es siehst. Eine stille Anweisung, mehr nicht.@@</p>
<<else>>
<p>@@.beziehung;Du blickst dich suchend nach vertrauten Gesichtern aus deiner Stube um. Du entdeckst Jarek und Karla, aber beide ignorieren dich starr.@@</p>
<</if>>
<<if $npc.karla.affection gt 0 or $npc.jarek.affection gt 0>>
<<link "Dich dank des Hinweises sofort ausrichten — du weißt, was zu tun ist.">>
<<if $npc.karla.affection gt 0>><<set $player.rel.karla += 1>><</if>>
<<if $npc.jarek.affection gt 0>><<set $player.rel.jarek += 1>><</if>>
<<set $player.chosen_activity to "zeigt_eigeninitiative">>
<<goto "Appell: Ausrichten">>
<</link>>
<</if>>
[[Warten, bis er es dir befiehlt. ->Appell: Ausrichten][$player.chosen_activity to "ist_befehlstreu"]]
<<if $npc.karla.affection lte 0 and $npc.jarek.affection lte 0>>
	[[Auf gut Glück versuchen dich auszurichten — du rätst, was verlangt ist. ->Appell: Ausrichten][$player.chosen_activity to "ist_panisch"]]
<</if>>

<<set $npc.hauptmann.known to true>>
<<set $npc.schinder.known to true>>
<<set $npc.kurt.known to true>>


